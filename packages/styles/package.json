{
  "name": "@heeh-ui/styles",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "src/*.css"
  ],
  "exports": {
    "./css": {
      "types": "./src/css.d.ts",
      "default": "./src/index.css"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
